---
interface Props {
  title: string;
  current?: string;
}

const { title, current = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Bikepacking Tour 2026</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚵</text></svg>" />
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-title">Georgia → Nice</a>
        <ul class="nav-links">
          <li><a href="/" aria-current={current === 'home' ? 'page' : undefined}>Overview</a></li>
          <li><a href="/route" aria-current={current === 'route' ? 'page' : undefined}>Route</a></li>
          <li><a href="/actions" aria-current={current === 'actions' ? 'page' : undefined}>Actions</a></li>
          <li><a href="/gear" aria-current={current === 'gear' ? 'page' : undefined}>Gear</a></li>
        </ul>
      </div>
    </nav>

    <main class="page-container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="page-container">
        Planning document · Last updated March 2026
      </div>
    </footer>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </body>
</html>

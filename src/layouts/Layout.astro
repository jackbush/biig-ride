---
interface Props {
    title: string;
    current?: string;
}

const { title, current = "" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} — Bikepacking Tour 2026</title>
        <link
            rel="icon"
            type="image/svg+xml"
            href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚵</text></svg>"
        />
    </head>
    <body>
        <nav class="site-nav">
            <div class="nav-inner">
                <a href={base} class="nav-title">Georgia → Nice</a>
                <ul class="nav-links">
                    <li class="nav-has-dropdown">
                        <a
                            href={`${base}/legs/1`}
                            aria-current={current === "legs"
                                ? "page"
                                : undefined}>Legs</a
                        >
                        <ul class="nav-dropdown-menu">
                            <li><a href={`${base}/legs/1`}>1 · Georgia</a></li>
                            <li><a href={`${base}/legs/2`}>2 · Turkey</a></li>
                            <li><a href={`${base}/legs/3`}>3 · Greece</a></li>
                            <li><a href={`${base}/legs/4`}>4 · Albania</a></li>
                            <li>
                                <a href={`${base}/legs/5`}>5 · Montenegro</a>
                            </li>
                            <li>
                                <a href={`${base}/legs/6`}>6 · Apennines</a>
                            </li>
                            <li>
                                <a href={`${base}/legs/7`}
                                    >7 · Alps — Piedmont</a>
                            </li>
                            <li>
                                <a href={`${base}/legs/8`}
                                    >8 · Alps — Dolomites</a>
                            </li>
                            <li>
                                <a href={`${base}/legs/9`}
                                    >9 · Alps — Austria & Switzerland</a>
                            </li>
                            <li>
                                <a href={`${base}/legs/10`}
                                    >10 · Alps — France & Nice</a>
                            </li>
                        </ul>
                    </li>
                    <li>
                        <a
                            href={`${base}/actions`}
                            aria-current={current === "actions"
                                ? "page"
                                : undefined}>Actions</a
                        >
                    </li>
                    <li>
                        <a
                            href={`${base}/gear`}
                            aria-current={current === "gear"
                                ? "page"
                                : undefined}>Gear</a
                        >
                    </li>
                </ul>
            </div>
        </nav>

        <main class="page-container">
            <slot />
        </main>

        <footer class="site-footer">
            <div class="page-container">
                Planning document · Last updated March 2026
            </div>
        </footer>

        <style is:global>
            @import "../styles/global.css";
        </style>
    </body>
</html>
